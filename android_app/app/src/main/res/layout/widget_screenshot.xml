<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="3dp"
    android:background="@drawable/widget_background">

    <!-- 显示区域：填满整个小部件，三行文字按权重瓜分高度，各自 autosize 自适应 -->
    <LinearLayout
        android:id="@+id/widget_time_display_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible">

        <!-- 第一行：主机名 -->
        <TextView
            android:id="@+id/widget_host_text"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3"
            android:text="PC"
            android:textSize="10sp"
            android:maxLines="1"
            android:textColor="#FF8000"
            android:textStyle="bold"
            android:gravity="center"
            android:includeFontPadding="false"
            android:padding="0dp"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="6sp"
            android:autoSizeMaxTextSize="72sp"
            android:autoSizeStepGranularity="1sp" />

        <!-- 第二行：个数 -->
        <TextView
            android:id="@+id/widget_update_time"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3"
            android:text="3 个"
            android:textSize="7sp"
            android:maxLines="1"
            android:textColor="#333333"
            android:textStyle="normal"
            android:gravity="center"
            android:includeFontPadding="false"
            android:padding="0dp"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="6sp"
            android:autoSizeMaxTextSize="72sp"
            android:autoSizeStepGranularity="1sp"
            android:visibility="visible" />

        <!-- 第三行：日期时间 -->
        <TextView
            android:id="@+id/widget_date_text"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="4"
            android:text=""
            android:textSize="12sp"
            android:maxLines="1"
            android:textColor="#333333"
            android:textStyle="bold"
            android:gravity="center"
            android:includeFontPadding="false"
            android:padding="0dp"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="6sp"
            android:autoSizeMaxTextSize="96sp"
            android:autoSizeStepGranularity="1sp" />

    </LinearLayout>

</LinearLayout>
